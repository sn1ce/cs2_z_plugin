{
    // Per-client cvars the plugin pushes to every player on connect AND on css_zreload.
    // This is the bus-level volume knob: snd_toolvolume affects the audio bus our
    // EmitSound + "play <path>" emissions land on. Edit value, save, css_zreload →
    // every connected player gets the new value instantly. No reconnect needed.
    "ClientCvars": {
        "snd_toolvolume": 0.1
    },

    // Each event has either:
    //   - "SoundEvent": "<name>"   → engine EmitSound (volume baked into the addon's .vsndevts)
    //   - "Files": ["sounds/...vsnd", ...] → client "play <path>" fallback (full volume, 2D)
    // "Volume" is advisory only for the "Files" path.
    //
    // Sources mounted via MAM:
    //   - 3160448201 = GFL ZE Content (raw vsnd paths under sounds/zr/...)
    //   - 3730087911 = Zombiemod Sounds (custom .vsndevts with ZombieMod.* events)
    // Live-reload via "css_zreload".

    // Ambient track — restarts on every OnRoundFreezeEnd. OnRoundEnd issues "stopsound"
    // so it cuts cleanly at the round boundary.
    // SoundEvent fallback: the "ZombieMod.Ambient" entry didn't compile into the workshop
    // addon's .vsndevts_c (Mother + Bite events made it, Ambient didn't — likely a stale
    // compile cache). Falls back to "play <path>" at full volume until the .vsndevts is
    // fixed and the addon is re-published.
    // Ambient: SoundEvent left empty because zm.ambTrack (type=csgo_default) is silent for
    // reasons we never untangled — engine accepts the emit, returns a valid handle, but
    // produces no audible output regardless of which entity we emit from. Falls back to
    // play <path> at full volume. Workaround: lower the source .wav amplitude in Audacity
    // if you eventually want it quieter; or wait for an updated EmitSoundVolumeFix +
    // change the .vsndevts type to cs_player_footstep (positional).
    "round_ambient": {
        "SoundEvent": "",
        "Volume": 1.0,
        "Files": [
            "sounds/zombie_event_ambient_sound.vsnd"
        ]
    },

    // Patient Zero identified at round start — engine picks one of the 2 vsnd_files in the
    // soundevent at random.
    "patient_zero": {
        "SoundEvent": "zm.MotherScream",
        "Volume": 0.1,
        "Files": [
            "sounds/zombie_event_random_scream.vsnd",
            "sounds/zombie_event_random_scream_1.vsnd"
        ]
    },

    // Survivor death — fires on OnPlayerDeath when victim was NOT infected at time of death.
    "survivor_death": {
        "SoundEvent": "zm.Bite",
        "Volume": 0.1,
        "Files": [
            "sounds/zombie_event_bite_scream.vsnd"
        ]
    },

    // GFL pack sounds (no .vsndevts) — use the "Files" path-based fallback.
    "infected_death": {
        "Volume": 0.1,
        "Files": [
            "sounds/zr/zombie_die1.vsnd",
            "sounds/zr/zombie_die2.vsnd",
            "sounds/zr/zombie_die3.vsnd"
        ]
    },

    "infected_idle": {
        "Volume": 0.1,
        "Files": [
            "sounds/zr/zombie_voice_idle1.vsnd",
            "sounds/zr/zombie_voice_idle2.vsnd",
            "sounds/zr/zombie_voice_idle3.vsnd",
            "sounds/zr/zombie_voice_idle4.vsnd",
            "sounds/zr/zombie_voice_idle5.vsnd",
            "sounds/zr/zombie_voice_idle6.vsnd",
            "sounds/zr/zombie_voice_idle7.vsnd",
            "sounds/zr/zombie_voice_idle8.vsnd",
            "sounds/zr/zombie_voice_idle9.vsnd",
            "sounds/zr/zombie_voice_idle10.vsnd",
            "sounds/zr/zombie_voice_idle11.vsnd",
            "sounds/zr/zombie_voice_idle12.vsnd",
            "sounds/zr/zombie_voice_idle13.vsnd",
            "sounds/zr/zombie_voice_idle14.vsnd"
        ]
    }
}
