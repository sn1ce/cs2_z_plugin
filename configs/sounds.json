{
    // Each event has either:
    //   - "SoundEvent": "<name>"   → engine EmitSound (volume baked into the addon's .vsndevts)
    //   - "Files": ["sounds/...vsnd", ...] → client "play <path>" fallback (full volume, 2D)
    // "Volume" is advisory only for the "Files" path.
    //
    // Sources mounted via MAM:
    //   - 3160448201 = GFL ZE Content (raw vsnd paths under sounds/zr/...)
    //   - 3730087911 = Zombiemod Sounds (custom .vsndevts with ZombieMod.* events)
    // Live-reload via "css_zreload".

    // Ambient track — restarts on every OnRoundFreezeEnd. The .vsndevts entry sets volume.
    // OnRoundEnd issues "stopsound" so it cuts cleanly at the round boundary.
    "round_ambient": {
        "SoundEvent": "ZombieMod.Ambient",
        "Volume": 0.5,
        "Files": [
            "sounds/zombie_event_ambient_sound.vsnd"
        ]
    },

    // Patient Zero identified at round start — engine picks one of the 2 vsnd_files in the
    // soundevent at random.
    "patient_zero": {
        "SoundEvent": "ZombieMod.MotherScream",
        "Volume": 0.5,
        "Files": [
            "sounds/zombie_event_random_scream.vsnd",
            "sounds/zombie_event_random_scream_1.vsnd"
        ]
    },

    // Survivor death — fires on OnPlayerDeath when victim was NOT infected at time of death.
    "survivor_death": {
        "SoundEvent": "ZombieMod.Bite",
        "Volume": 0.5,
        "Files": [
            "sounds/zombie_event_bite_scream.vsnd"
        ]
    },

    // GFL pack sounds (no .vsndevts) — use the "Files" path-based fallback.
    "infected_death": {
        "Volume": 0.5,
        "Files": [
            "sounds/zr/zombie_die1.vsnd",
            "sounds/zr/zombie_die2.vsnd",
            "sounds/zr/zombie_die3.vsnd"
        ]
    },

    "infected_idle": {
        "Volume": 0.5,
        "Files": [
            "sounds/zr/zombie_voice_idle1.vsnd",
            "sounds/zr/zombie_voice_idle2.vsnd",
            "sounds/zr/zombie_voice_idle3.vsnd",
            "sounds/zr/zombie_voice_idle4.vsnd",
            "sounds/zr/zombie_voice_idle5.vsnd",
            "sounds/zr/zombie_voice_idle6.vsnd",
            "sounds/zr/zombie_voice_idle7.vsnd",
            "sounds/zr/zombie_voice_idle8.vsnd",
            "sounds/zr/zombie_voice_idle9.vsnd",
            "sounds/zr/zombie_voice_idle10.vsnd",
            "sounds/zr/zombie_voice_idle11.vsnd",
            "sounds/zr/zombie_voice_idle12.vsnd",
            "sounds/zr/zombie_voice_idle13.vsnd",
            "sounds/zr/zombie_voice_idle14.vsnd"
        ]
    }
}
