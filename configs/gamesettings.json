{
    // Delay before Patient Zero is identified (after freezetime ends), in seconds.
    "FirstInfectionTimer": 15.0,

    // Cash floor at round start — players below this get topped up, players above keep theirs.
    "StartMoney": 4000,

    // Cash bonus awarded to an infected on each successful knife-transmission.
    "InfectKillReward": 500,

    // Patient Zero ratio. Example: 21 players / 7 = 3 patient zeros.
    "PatientZeroRatio": 7.0,

    // Teleport Patient Zero back to spawn after infection (Zombie Escape style).
    "PatientZeroTeleport": false,

    // Award cash on damage dealt to survivors.
    "CashOnDamage": false,

    // When round timer expires: 0 = infected win, 1 = survivors win.
    "TimeoutWinner": 1,

    // Default class IDs (must match keys in classes.json).
    "DefaultSurvivorBuffer": "survivor_default",
    "DefaultInfectedBuffer": "infected_default",
    "PatientZeroBuffer": "patient_zero",

    // Random class assignment.
    "RandomClassesOnConnect": false,
    "RandomClassesOnSpawn": true,

    // Weapon system master toggles.
    "WeaponPurchaseEnable": true,
    "WeaponRestrictEnable": true,
    "WeaponBuyZoneOnly": false,

    // !ztele teleport.
    "TeleportAllow": true,
    "TeleportUsesPerRound": 1,
    "TeleportCooldownSeconds": 60.0,

    // Respawn handling.
    "RespawnEnable": true,
    "RespawnDelay": 5.0,
    "AllowRespawnJoinLate": false,
    // 0 = infected, 1 = survivor, 2 = pre-death team.
    "RespawnTeam": 0,

    // Per-class speed override (Speed in classes.json). 250 = default CS2 speed; higher = faster.
    // Flip false if you see weapon-attachment glitches that correlate with speed swaps.
    "EnableClassSpeed": true,

    // Strip hostages on cs_* maps so they don't interfere with zombie rounds (NPCs blocking
    // paths, CTs auto-winning on rescue, AI noise). Plugin watches OnEntityCreated for
    // "hostage_entity" and kills them 0.1s after spawn.
    "RemoveHostages": true,

    // Turn every human player's flashlight ON automatically on each spawn. They can still
    // press E or type !fl to toggle it off. Bots are skipped (they'd never use it).
    "FlashlightDefaultOn": true,

    // After this many rounds the plugin rotates to the next entry in MapRotation.
    "MaxRoundsPerMap": 15,

    // Map rotation. Numeric strings → Steam Workshop IDs (host_workshop_map),
    // otherwise treated as vanilla map names (changelevel).
    // Empty list = stay on the current map forever.
    "MapRotation": [ "de_dust2", "3312510632" ]
}
